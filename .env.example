# ──────────────────────────────────────────────
# PantryPal API — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Values marked [TF] are auto-populated by `npm run env:from-tf`

# Server
PORT=8788
FRONTEND_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>?schema=pantrypal_app

# AWS Cognito  [TF]
COGNITO_REGION=us-east-2
COGNITO_USER_POOL_ID=us-east-2_xxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS General
AWS_REGION=us-east-2

# AWS Bedrock
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# AWS S3  [TF]
PANTRY_IMAGES_BUCKET=pantrypal-pantry-images
S3_BUCKET_RECIPE_CACHE=pantrypal-recipe-cache

# Spoonacular
SPOONACULAR_API_KEY=<key>

# Optional — AI recipe images
UNSPLASH_ACCESS_KEY=<key>
